# ============================================
# Craftistan Frontend — Environment Variables
# ============================================
# Copy this file to .env.local for local dev:
#   cp .env.example .env.local
# In production (Vercel), add these as
# Environment Variables in the project settings.
# ============================================

# Backend API base URL
# Dev:  leave blank — Vite proxy forwards /api → http://localhost:8080
# Prod: set to your Railway backend URL
VITE_API_BASE_URL=https://your-backend.up.railway.app
